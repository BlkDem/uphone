# UPhone Server Configuration
# Copy to /etc/uphone/uphone.env and edit

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=uphone
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=uphone

# Server
SERVER_PORT=8080
UPLOAD_DIR=/var/lib/uphone/uploads
UPLOAD_BASE_URL=http://SERVER_IP
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
